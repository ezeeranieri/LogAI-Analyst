# LogAI-Analyst Environment Configuration
# Copy this file to .env and fill in your actual values
# WARNING: API_KEY is REQUIRED. The application will fail to start if not set.

# Data directory path (relative to project root)
DATA_DIR=data

# API security key - REQUIRED: Generate a strong random value (e.g., openssl rand -hex 32)
# There is NO default - the app will crash on startup if not set.
API_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_32_CHARS_MIN

# Log file path
LOG_FILE=app_production.log

# Application host and port
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional: Custom model path (defaults to DATA_DIR/model.pkl)
# MODEL_PATH=data/model.pkl

# Optional: Redis URL for distributed rate limiting in multi-worker environments
# REDIS_URL=redis://localhost:6379/0
